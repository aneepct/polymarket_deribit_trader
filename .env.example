# ── Django core ───────────────────────────────────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-django-secret-key-here

DEBUG=False
ALLOWED_HOSTS=*

# ── Encryption key for DB-stored secrets ─────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: changing this key will make existing encrypted values unreadable.
FIELD_ENCRYPTION_KEY=your-fernet-key-here

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://trader:changeme@db:5432/trader
POSTGRES_DB=trader
POSTGRES_USER=trader
POSTGRES_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
